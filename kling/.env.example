# ─────────────────────────────────────────────────────────────────────────────
# .env.example  —  COPIA este archivo como  .env  y pega TUS valores.
# NUNCA subas el .env con valores reales a git (ya está en .gitignore).
# Cada quien usa SUS PROPIAS cuentas (kie.ai, fal.ai, ElevenLabs).
#
# IMPORTANTE: pon el valor SOLO, sin comentarios en la misma línea.
#   Correcto:    KIE_API_KEY=abc123
#   Incorrecto:  KIE_API_KEY=abc123   # esto se toma como parte de la clave
# ─────────────────────────────────────────────────────────────────────────────

# --- OBLIGATORIAS para el core (keyframes + animación + transcripción) ---

# kie.ai → keyframes (nano-banana) + video (Kling 3.0)
KIE_API_KEY=

# fal.ai → transcripción (Whisper), lipsync, subir imágenes
FAL_KEY=

# --- OPCIONAL (solo si usas post-producción de voz TTS) ---

# ElevenLabs → generar voz del narrador (postpro/tts_eleven.ps1)
ELEVENLABS_API_KEY=

# --- OPCIONAL (rutas de ffmpeg si NO están en el PATH) ---
# Déjalas vacías si ffmpeg/ffprobe ya están en el PATH del sistema.
# Ejemplo: FFMPEG=C:\ffmpeg\bin\ffmpeg.exe
FFMPEG=
FFPROBE=

# --- OPCIONAL (legacy, NO usar salvo que corras scripts PiAPI viejos) ---
PIAPI_KEY=
