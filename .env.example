# ─────────────────────────────────────────────────────────────────────────────
# .env.example  —  COPIA como  .env  y pega TUS valores (cuentas propias).
# NUNCA subas el .env a git (ya está en .gitignore).
# IMPORTANTE: el valor va SOLO, sin comentarios en la misma línea.
# ─────────────────────────────────────────────────────────────────────────────

# ===== FASE 0 — Research (Apify / TrendTrack) =====
# Apify → scraping de VoC (reddit, tiktok, youtube, amazon) y ads de competencia
APIFY_TOKEN=
# TrendTrack → ads del nicho para rankear e imitar
TRENDTRACK_TOKEN=

# ===== ETAPA 3 — Pegasus (análisis visual de video) =====
# TwelveLabs → https://twelvelabs.io
TL_API_KEY=
# Opcional: si ya tienes un índice, ponlo aquí; si no, el script crea "autgg-pegasus"
TL_INDEX_ID=

# ===== ETAPA 4 — Kling (producción de video) =====
# kie.ai → keyframes (nano-banana) + video (Kling 3.0)
KIE_API_KEY=
# fal.ai → transcripción, lipsync, subir imágenes
FAL_KEY=
# ElevenLabs → voz TTS (opcional, solo si no grabas voz real)
ELEVENLABS_API_KEY=

# ===== OPCIONAL — rutas de ffmpeg si NO están en el PATH =====
# Ejemplo: FFMPEG=C:\ffmpeg\bin\ffmpeg.exe
FFMPEG=
FFPROBE=
