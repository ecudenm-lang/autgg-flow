# ─────────────────────────────────────────────────────────────────────────────
# .env.example  —  COPIA como  .env  y pega TUS valores (cuentas propias).
# NUNCA subas el .env a git (ya está en .gitignore).
# IMPORTANTE: el valor va SOLO, sin comentarios en la misma línea.
# ─────────────────────────────────────────────────────────────────────────────

# ===== PASO 1 — Market Research (Apify) =====
# Apify → VoC (reddit, tiktok, youtube, amazon) + entendimiento de mercado
APIFY_TOKEN=

# ===== PASO 2 — Scraping Competencia (TrendTrack) =====
# TrendTrack → ads del nicho/competencia para rankear e imitar
TRENDTRACK_TOKEN=

# ===== PASO 3 — Fábrica de Videos (Pegasus + Kling) =====
# TwelveLabs (Pegasus) → análisis visual del video. https://twelvelabs.io
TL_API_KEY=
# Opcional: si ya tienes un índice, ponlo aquí; si no, el script crea "autgg-pegasus"
TL_INDEX_ID=
# kie.ai (Kling) → keyframes (nano-banana) + video (Kling 3.0)
KIE_API_KEY=
# fal.ai (Kling) → transcripción, lipsync, subir imágenes
FAL_KEY=
# ElevenLabs → voz TTS (opcional, solo si no grabas voz real)
ELEVENLABS_API_KEY=

# ===== PASO 4 — Growth Guide =====
# (por definir — el registro historico aun no necesita claves)

# ===== OPCIONAL — rutas de ffmpeg si NO están en el PATH =====
# Ejemplo: FFMPEG=C:\ffmpeg\bin\ffmpeg.exe
FFMPEG=
FFPROBE=
